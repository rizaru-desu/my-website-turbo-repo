apps/backend/*.exe~
apps/backend/*.dll
apps/backend/*.so
apps/backend/*.dylib
apps/backend/*.test
apps/backend/*.out
apps/backend/coverage.out
apps/backend/build-errors.log

# Frontend apps
apps/frontend/admin/logs
apps/frontend/public/logs
apps/frontend/admin/*.log
apps/frontend/public/*.log
apps/frontend/admin/pnpm-debug.log*
apps/frontend/public/pnpm-debug.log*
