{
  "name": "portofolio-lightweight",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:linux": "sh ./scripts/build-linux.sh amd64",
    "build:linux:arm64": "sh ./scripts/build-linux.sh arm64",
    "dev": "pnpm --parallel --filter ./apps/backend --filter ./apps/frontend/admin --filter ./apps/frontend/public run dev",
    "dev:api": "pnpm --filter ./apps/backend run dev",
    "dev:web": "pnpm --parallel --filter ./apps/frontend/admin --filter ./apps/frontend/public run dev",
    "dev:turbo": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
