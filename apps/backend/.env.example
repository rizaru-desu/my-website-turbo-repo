APP_ENV=development
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
DATABASE_URL=postgres://postgres:postgres@localhost:5432/portfolio_lightweight?sslmode=disable
DB_AUTO_MIGRATE=false

# SMTP Mail (for forgot password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-without-spaces
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=Portfolio Admin

# Frontend URL (for reset password link)
FRONTEND_URL=http://localhost:3111
